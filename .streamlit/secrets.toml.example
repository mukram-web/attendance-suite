# ─────────────────────────────────────────────────────────────────────────────
# secrets.toml.example  →  rename to  secrets.toml  to turn ON live Google mode.
#
# • Locally:  put the real file at  .streamlit/secrets.toml  (it is gitignored).
# • Deployed: paste this same content into your app's Settings → Secrets on
#   share.streamlit.io (do NOT commit the real keys).
#
# Full step-by-step (non-technical) instructions are in SETUP_LIVE.md.
# ─────────────────────────────────────────────────────────────────────────────

# 1) The service-account ("robot Google login") JSON key, field by field.
#    Open the .json file you downloaded from Google Cloud and copy each value.
[gcp_service_account]
type = "service_account"
project_id = "your-project-id"
private_key_id = "xxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxx"
# Keep the \n characters exactly as they appear in the JSON file:
private_key = "-----BEGIN PRIVATE KEY-----\nMIIE...\n...\n-----END PRIVATE KEY-----\n"
client_email = "attendance-robot@your-project-id.iam.gserviceaccount.com"
client_id = "000000000000000000000"
auth_uri = "https://accounts.google.com/o/oauth2/auth"
token_uri = "https://oauth2.googleapis.com/token"
auth_provider_x509_cert_url = "https://www.googleapis.com/oauth2/v1/certs"
client_x509_cert_url = "https://www.googleapis.com/robot/v1/metadata/x509/attendance-robot%40your-project-id.iam.gserviceaccount.com"
universe_domain = "googleapis.com"

# 2) Which Google files to read. The ID is the long code in each file's URL.
#    Share all three with the robot's client_email (Viewer) first!
[drive]
roster_id = "PUT_THE_ROSTER_GOOGLE_SHEET_FILE_ID_HERE"      # required
l2_id     = "PUT_THE_L2_SCHEDULE_GOOGLE_SHEET_FILE_ID_HERE" # recommended

# Attendee data — use ONE of these two:
# A Drive folder / Shared Drive of dated Zoom-export folders (recommended). The app
# reads the roster's existing marks for ALL history and only marks the NEW sessions
# (dates not yet in the roster), so it stays fast even with hundreds of folders.
attendee_folder_id = "PUT_THE_ATTENDEE_FOLDER_OR_SHARED_DRIVE_ID_HERE"
# attendee_zip_id  = "PUT_THE_ATTENDEE_ZIP_FILE_ID_HERE"    # ...or a single .zip you replace each week

# Optional: set true to re-mark EVERYTHING from the Drive (full rebuild), ignoring
# what's already in the roster. Leave unset/false for the fast incremental default.
# mark_all = false
